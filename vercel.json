{
  "rewrites": [
    { "source": "/app", "destination": "/studlin-web-app.html" },
    { "source": "/app/(.*)", "destination": "/studlin-web-app.html" },
    { "source": "/network", "destination": "/studlin-web-app.html" },
    { "source": "/onboarding", "destination": "/studlin-onboarding.html" },
    { "source": "/signup", "destination": "/studlin-onboarding.html" },
    { "source": "/signin", "destination": "/studlin-sign-in.html" },
    { "source": "/login", "destination": "/studlin-sign-in.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" }
  ],
  "functions": {
    "api/create-intent.js": { "memory": 256, "maxDuration": 10 },
    "api/search-videos.js": { "memory": 128, "maxDuration": 10 },
    "api/chat.js": { "memory": 256, "maxDuration": 30 },
    "api/me.js": { "memory": 256, "maxDuration": 60 },
    "api/stripe-webhook.js": { "memory": 256, "maxDuration": 15 },
    "api/notify.js": { "memory": 256, "maxDuration": 10 },
    "api/send-verification.js": { "memory": 256, "maxDuration": 10 },
    "api/cal-proxy.js": { "memory": 256, "maxDuration": 10 },
    "api/export-users.js": { "memory": 256, "maxDuration": 30 },
    "api/get-shared-chat.js": { "memory": 128, "maxDuration": 10 }
  },
  "crons": [
    { "path": "/api/me", "schedule": "0 8 * * *" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/checkout.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/studlin-app.jsx",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }]
    },
    {
      "source": "/signin.jsx",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/onboarding.jsx",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://js.stripe.com https://unpkg.com https://www.gstatic.com https://www.google.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://accounts.google.com https://us-assets.i.posthog.com https://browser.sentry-cdn.com https://www.googletagmanager.com 'unsafe-inline' 'unsafe-eval'; frame-src https://js.stripe.com https://www.youtube.com https://www.youtube-nocookie.com https://www.google.com; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.cloudfunctions.net wss://*.firebaseio.com https://accounts.google.com https://securetoken.googleapis.com https://identitytoolkit.googleapis.com https://us.i.posthog.com https://us-assets.i.posthog.com https://www.google-analytics.com https://analytics.google.com https://o4511706335281152.ingest.us.sentry.io https://api.pwnedpasswords.com https://www.google.com; img-src 'self' https://img.youtube.com https://upload.wikimedia.org https://en.wikipedia.org data:; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src https://fonts.gstatic.com" }
      ]
    }
  ]
}
