rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All Studlin data access goes through Vercel API routes using the
    // Firebase Admin SDK, which always bypasses these rules. Direct client
    // reads/writes are never legitimate, so deny everything by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
