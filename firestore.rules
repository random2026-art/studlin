rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Private account data: credits, plan, billing, email. Reads still go
    // exclusively through Vercel API routes using the Firebase Admin SDK
    // (which bypasses these rules), so this stays unreadable to clients.
    // Writes are opened up ONLY for the specific onboarding fields the
    // client sets directly from InitWizard — anything else (credits, plan,
    // email...) is rejected even if a client tries to sneak it into the
    // same update, because affectedKeys() must be a subset of this list.
    match /users/{userId} {
      allow read: if false;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status','affiliation','school','workStartTime','workEndTime','bedtime','bedtimeGuardEnabled','difficultyPreference','taskDifficultyPreference','bufferMarginStrategy','onboarded','onboardedAt','updatedAt','preferences','fcmTokens']);
    }

    // Public directory entry — just enough to search for and display a
    // classmate (name/username/school). Any signed-in user can read/query
    // this (that's what search needs); only the owner can write their own.
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Friend requests / relationships between two real users.
    // - Only readable by the two people involved.
    // - Only creatable by the authenticated sender, targeting someone else,
    //   and must start life as 'pending'.
    // - Only the receiver can flip a pending request to 'accepted'; the
    //   sender/receiver ids can never change on update.
    // - Either party may delete (unfriend, cancel a sent request, or
    //   decline an incoming one).
    match /friendships/{friendshipId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.senderId
        && request.resource.data.senderId != request.resource.data.receiverId
        && request.resource.data.status == 'pending';
      allow update: if request.auth != null
        && request.auth.uid == resource.data.receiverId
        && resource.data.status == 'pending'
        && request.resource.data.status == 'accepted'
        && request.resource.data.senderId == resource.data.senderId
        && request.resource.data.receiverId == resource.data.receiverId;
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
    }

    // Durable assignment/course identity seeded from the (mocked) Canvas
    // connector. Owned entirely per-user; the actual scheduling of calendar
    // blocks happens client-side against the existing `events` localStorage
    // array, never here — these two collections only track "what/when/how-
    // estimated", not "which time slots are booked."
    match /courses/{courseId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.userId
        && request.resource.data.userId == resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /assignments/{assignmentId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.userId
        && request.resource.data.userId == resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Real-time chat — DMs and groups share one collection so both can be
    // driven by a single `memberUids array-contains` inbox query. `messages`
    // writes must be self-attributed (senderId == auth.uid), so a client can
    // never fabricate a message "from" someone else. Membership/createdBy
    // are frozen after creation; only the creator can delete the room.
    match /chatRooms/{roomId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.memberUids;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.memberUids.size() >= 2
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null && request.auth.uid in resource.data.memberUids
        && request.resource.data.memberUids == resource.data.memberUids
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.memberUids;
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.senderId
          && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.memberUids;
        // Fields beyond status/scheduledOption/scheduledMode were added when
        // the propose/accept/decline negotiation flow shipped (see
        // scheduleGroupSession/respondToShare's calendar branch in
        // studlin-app.jsx), but this allowlist was never updated to match --
        // every one of those writes touched proposedBy/memberUids/
        // studySessionId/responses, none of which were allowed, so Firestore
        // silently rejected the entire update (all-or-nothing per write) and
        // the app's own empty .catch(()=>{}) masked it as success locally.
        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.memberUids
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','scheduledOption','scheduledMode','proposedBy','memberUids','studySessionId','responses']);
        allow delete: if false;
      }
    }

    // Real live study sessions — shared/parallel Lock-In. memberUids is
    // frozen at create, same convention as chatRooms, and drives every
    // membership check below. Rules can't cheaply restrict "may only write
    // your own key inside participants" (Firestore rules operate on whole-
    // document diffs, not per-map-key ACLs) — chatRooms already accepts this
    // same trust boundary for memberNames, so this mirrors that posture
    // rather than inventing a workaround; every member is already an
    // accepted friend.
    match /studySessions/{sessionId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.memberUids;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.memberUids.size() >= 2
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'scheduled'
        && request.resource.data.startedBy == null;
      allow update: if request.auth != null && request.auth.uid in resource.data.memberUids
        && request.resource.data.memberUids == resource.data.memberUids
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['participants','status','startedBy','startedAt','endedAt','updatedAt']);
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;
    }

    // Opt-in shared free/busy for "Find Shared Study Window" (Studlin
    // Match) — busy TIME intervals only (see computeBusyWindowsPayload in
    // studlin-app.jsx), never event titles/kinds/subjects. Doc id is the
    // owner's own uid. sharedWithUids is a denormalized snapshot of the
    // owner's current accepted friends, refreshed on every publish
    // (publishBusyWindows) — rules can't cheaply join against the
    // `friendships` collection (no deterministic doc id for a pair), so
    // this mirrors chatRooms/studySessions' own memberUids trust boundary
    // instead. A friend removed since the last publish keeps read access
    // until the next publish/toggle-off — same staleness window
    // chatRooms/studySessions already accept for their own membership
    // arrays, not a new gap introduced here.
    match /busyWindows/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || request.auth.uid in resource.data.sharedWithUids);
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.ownerUid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Username reservations — a doc ID existing at all means that handle is
    // taken. Client claims one atomically in a transaction alongside the
    // profiles/{uid}.username write (see onboarding.jsx finishOnboarding()).
    // Once created a reservation is permanent: no update/delete, so a handle
    // can never be silently reassigned out from under its owner.
    match /usernames/{uname} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && uname.matches('^[a-z][a-z0-9_]{2,19}$');
      allow update, delete: if false;
    }

    // Shared, cross-user school/university directory for SchoolSelect's
    // autocomplete (studlin-app.jsx) -- same shape as usernames above: the
    // doc id existing at all means that school is already known, so the
    // second student at the same school finds it instead of retyping it
    // fresh. schoolId is a client-computed slug of the name; once created
    // a doc is permanent (no update/delete) so it can never be silently
    // renamed or removed out from under students already relying on it.
    match /schools/{schoolId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.type in ['highschool','college']
        && schoolId.matches('^[a-z0-9-]{1,100}$');
      allow update, delete: if false;
    }

    // Shared AI chat conversations — public by design. Anyone with the share
    // ID can read. Only authenticated users can create (share). Immutable
    // once created: no updates or deletes.
    match /shared_chats/{shareId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // emailOtps is written/read exclusively by the Vercel API routes via the
    // Admin SDK (which bypasses these rules) — never by the client directly.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
